{
  "name": "flovia-baseprivynyc",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run scripts/dev.ts",
    "dev:e2e": "bun run scripts/dev.ts e2e --budget 0.25 --privy-authorized",
    "e2e": "bun run dev:e2e",
    "dev:web": "bun run --filter='web' dev",
    "dev:api": "bun run --filter='api' dev",
    "dev:merchant": "bun run --filter='merchant-api' dev",
    "dev:agent": "bun run --filter='demo-agent' dev",
    "test": "bun run --filter='*' test",
    "typecheck": "bun run --filter='*' typecheck",
    "db:migrate": "bun run --filter='@flovia-baseprivynyc/db' db:migrate",
    "db:seed": "bun run --filter='@flovia-baseprivynyc/db' db:seed"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.5",
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.10.7",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
